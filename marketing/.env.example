# =============================================================================
# Public-facing marketing site for dentaloptima-core
# =============================================================================
# Patient-facing site that serves N practices from one deployment, resolved
# per-request from the hostname. Booking + contact forms write to the shared
# Supabase project via SECURITY DEFINER RPCs (anon-callable).
#
# Most VITE_PRACTICE_* values that were here in the legacy single-tenant
# template are gone — practice identity, contact, address, hours, branding,
# and the bookable-services list all come from the DB at boot. Static
# marketing copy (services long-form bodies, team bios, testimonials, hero)
# still lives in src/config/practice.config.ts and is shared across all
# practices that use this template — fork the file per practice when you
# need divergent copy.
# =============================================================================

# Shared dentaloptima-core Supabase project (anon key)
VITE_SUPABASE_URL=https://jvwuorwfzoutojpyjnfk.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional dev-only override: force a specific tenant during local dev
# without DNS jiggery-pokery. Falls back to window.location.hostname.
# Equivalent runtime override: append ?dev_hostname=foo to the URL once
# (sticky via sessionStorage, dev mode only).
VITE_PRACTICE_HOSTNAME=
