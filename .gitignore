node_modules/
# dist/ — intentionally tracked so deploys can pull pre-built bundles from
# the repo without running npm install + build first. If you ever switch to
# CI-built deploys (GitHub Actions → host), re-add `dist/` here.
.env
.env.local
.env.*.local
.env.migration
scripts/.env.migration
.DS_Store
*.log
.vscode/
.idea/
supabase/.branches/
supabase/.temp/

# Contains Supabase PAT — never commit
.mcp.json

# Claude Code per-user state. settings.local.json caches approved Bash
# commands which can include literal secret strings from past sessions;
# scheduled_tasks.lock is a runtime artefact.
.claude/

# Editor / OS junk
Thumbs.db
*.swp
*~

# Build artefacts
*.tsbuildinfo
coverage/

# Operator training videos — large binary, not source. Hosted elsewhere
# (helpGuides.ts references YouTube IDs).
Guide Videos/
