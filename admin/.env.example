# Two-Supabase-project setup. Operator-only admin: tenant-registry holds
# operator/internal data + auth; dentaloptima-core holds tenant/client data.

# === Tenant-registry (operator/internal — auth lives here) ================
# Project ref: hbsuhalvececxvusrqlh
VITE_REGISTRY_SUPABASE_URL=https://hbsuhalvececxvusrqlh.supabase.co
VITE_REGISTRY_SUPABASE_ANON_KEY=sb_publishable_O8shOjfvLsKNNXlTQjSsgQ_0OIHS-AI

# === Dentaloptima-core (tenant data — service-role bypasses RLS) ==========
# Project ref: jvwuorwfzoutojpyjnfk
#
# This admin uses the service role key directly because operators have full
# cross-tenant read/write access by design (support, billing, escalations).
# Edge functions still hold service-role server-side for the few flows that
# need auth.admin APIs (create-practice-with-owner, invite-member).
#
# ⚠ The service role key BYPASSES RLS for ALL tables. It MUST stay out of
# any other app's bundle. The .gitignore already excludes admin/.env.local
# and admin/dist/ — verify before committing.
VITE_SUPABASE_URL=https://jvwuorwfzoutojpyjnfk.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable__0LyuA_4XAvpNezzvdtQ4A_5hJXhVpJ
VITE_SUPABASE_SERVICE_ROLE_KEY=

# === Legacy operator token (deprecated) ===================================
# No longer used; left blank.
VITE_OPERATOR_TOKEN=
