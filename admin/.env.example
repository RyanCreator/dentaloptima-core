# Copy to .env.local and fill in values from the Supabase dashboard.
# (Project Settings → API for URL/anon key, Edge Functions → Secrets you set yourself.)

# dentaloptima-core Supabase project (read-only / anon key used by the admin's
# authenticated session — RLS enforces practice scoping).
VITE_SUPABASE_URL=https://jvwuorwfzoutojpyjnfk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Operator token used to call create-practice-with-owner edge function.
# Held in the OPERATOR_TOKEN edge-function secret on the server side.
# We send it from the browser only because this admin app is operator-only
# and the token rotates per environment. NEVER ship this to a client app.
VITE_OPERATOR_TOKEN=78ca4cf8074f0080abf53668dcde742b85077ddd80467aa8a9e7c29a1301a470
